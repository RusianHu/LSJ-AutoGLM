# Open-AutoGLM 启动器环境变量示例
# 用法：复制为 .env 并填写真实值（.env 会被 .gitignore 忽略）

# ---------- 启动器默认配置（会覆盖 launcher.py 内默认值） ----------
OPEN_AUTOGLM_BASE_URL=https://api-inference.modelscope.cn/v1
OPEN_AUTOGLM_MODEL=ZhipuAI/AutoGLM-Phone-9B

# 默认启动预设 (modelscope / zhipu / newapi / local_openai)
# 设置此项会自动覆盖上面的 BASE_URL 和 MODEL，并加载对应的 API Key
# OPEN_AUTOGLM_DEFAULT_PRESET=modelscope

# 推荐：把 Key 放在这里（不要写进代码/仓库）
OPEN_AUTOGLM_API_KEY=
OPEN_AUTOGLM_BACKUP_API_KEY=

# 可选：指定目标设备（例如 77eaf689 或 192.168.x.x:5555）
OPEN_AUTOGLM_DEVICE_ID=

# 设备平台：adb / hdc / ios
OPEN_AUTOGLM_DEVICE_TYPE=adb

# cn / en
OPEN_AUTOGLM_LANG=cn
OPEN_AUTOGLM_MAX_STEPS=100

# 动作策略（JSON 数组优先；为空时可回退到平台注册表默认值）
OPEN_AUTOGLM_ACTION_POLICY_VERSION=1
OPEN_AUTOGLM_USE_PLATFORM_DEFAULT_ACTIONS=true
# 运行时白名单，例如 ["Launch", "Tap", "Type"]
OPEN_AUTOGLM_ENABLED_ACTIONS=
# 提示词暴露给模型的动作集合；必须是运行时白名单子集
OPEN_AUTOGLM_AI_VISIBLE_ACTIONS=

# 第三方模型提示词工程（true/false）
OPEN_AUTOGLM_USE_THIRDPARTY_PROMPT=false
# 第三方输出 <think>/<answer>（true/false）
OPEN_AUTOGLM_THIRDPARTY_THINKING=true
# 截图压缩（true/false）
OPEN_AUTOGLM_COMPRESS_IMAGE=false

# ---------- 渠道专属配置（供 GUI/TUI 快速切换渠道读取） ----------
# ModelScope
OPEN_AUTOGLM_MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
OPEN_AUTOGLM_MODELSCOPE_MODEL=ZhipuAI/AutoGLM-Phone-9B
OPEN_AUTOGLM_MODELSCOPE_API_KEY=
OPEN_AUTOGLM_MODELSCOPE_BACKUP_API_KEY=

# 智谱 BigModel
OPEN_AUTOGLM_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPEN_AUTOGLM_ZHIPU_MODEL=AutoGLM-Phone-9B
OPEN_AUTOGLM_ZHIPU_API_KEY=

# 第三方中转站 / 服务
OPEN_AUTOGLM_NEWAPI_API_KEY=
OPEN_AUTOGLM_NEWAPI_BASE_URL=https://ai.yanshanlaosiji.top/v1
OPEN_AUTOGLM_NEWAPI_MODEL=Qwen/Qwen3-VL-235B-A22B-Instruct
# newapi 渠道行为开关（可选）
OPEN_AUTOGLM_NEWAPI_USE_THIRDPARTY_PROMPT=true
OPEN_AUTOGLM_NEWAPI_THIRDPARTY_THINKING=true

# 本地 OpenAI 兼容服务
OPEN_AUTOGLM_LOCAL_OPENAI_BASE_URL=http://127.0.0.1:1234
OPEN_AUTOGLM_LOCAL_OPENAI_MODEL=autoglm-phone-9b
# 本地 OpenAI 兼容服务的可选 Key（可选）
OPEN_AUTOGLM_LOCAL_OPENAI_API_KEY=
# 部分本地 OpenAI 兼容服务允许空 Key（可选）
OPEN_AUTOGLM_LOCAL_OPENAI_ALLOW_EMPTY_KEY=true

# ---------- 专家模式（可选） ----------
# 启用后，使用独立的多模态专家模型辅助主模型决策
OPEN_AUTOGLM_EXPERT_MODE=false
# 严格模式：每个主模型决策步骤前都咨询专家
OPEN_AUTOGLM_EXPERT_STRICT_MODE=false
OPEN_AUTOGLM_EXPERT_BASE_URL=
OPEN_AUTOGLM_EXPERT_MODEL=
OPEN_AUTOGLM_EXPERT_API_KEY=
# 可选的专家提示词覆盖
OPEN_AUTOGLM_EXPERT_PROMPT=
# 自动初始化与卡住救援
OPEN_AUTOGLM_EXPERT_AUTO_INIT=true
OPEN_AUTOGLM_EXPERT_AUTO_RESCUE=true
OPEN_AUTOGLM_EXPERT_MANUAL_ACTION=true
OPEN_AUTOGLM_EXPERT_SCREEN_UNCHANGED_THRESHOLD=4
OPEN_AUTOGLM_EXPERT_CONSECUTIVE_FAILURE_THRESHOLD=3
OPEN_AUTOGLM_EXPERT_MAX_RESCUES=3

# ---------- 其他 ----------
# 启动器配置持久化文件路径（可选）
# OPEN_AUTOGLM_LAUNCHER_CONFIG=C:\Users\YOURNAME\.open-autoglm-launcher.json

# ADBKeyboard.apk 路径（可选）
# OPEN_AUTOGLM_ADBKEYBOARD_APK=C:\path\to\ADBKeyboard.apk

# adb 可执行文件路径（可选；相对路径按程序目录解析）
# OPEN_AUTOGLM_ADB_PATH=C:\path\to\adb.exe

# 指定 .env 文件路径（可选，默认：项目根目录 .env）
OPEN_AUTOGLM_ENV_PATH=.env

# 安全开关：允许从 .open-autoglm-launcher.json 读取/写入 API Key（不推荐）
OPEN_AUTOGLM_ALLOW_CONFIG_FILE_SECRETS=false

# GUI 主题：system / dark / light
OPEN_AUTOGLM_THEME=system

# GUI：设备镜像优先在新窗口中打开（true/false）
OPEN_AUTOGLM_GUI_MIRROR_NEW_WINDOW=true

# GUI：显示设备镜像侧边工具栏（true/false）
OPEN_AUTOGLM_GUI_MIRROR_TOOLBAR=true

# GUI：侧边工具栏按钮集合（JSON 数组；留空时使用全部按钮）
OPEN_AUTOGLM_GUI_MIRROR_TOOLBAR_ACTIONS=["fullscreen","menu","home","back","app_switch","power","screenshot","volume_up","volume_down","screen_on","screen_off","notifications","touch","clipboard"]
